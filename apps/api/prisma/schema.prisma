generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  other
}

enum InterestedIn {
  male
  female
  everyone
}

enum MatchStatus {
  active
  unmatched
  blocked
}

enum StoryMediaType {
  image
  text
}

enum ShareTargetType {
  profile
  story
}

enum ConversationType {
  direct
}

enum MessageType {
  text
  image
  file
  audio
}

enum NotificationType {
  match_created
  new_message
  new_like
  story_reaction
  system
}

enum ReportStatus {
  open
  reviewed
  rejected
  actioned
}

enum GroupMemberRole {
  owner
  admin
  member
}

model User {
  id                String                    @id @default(uuid())
  email             String                    @unique
  phone             String?                   @unique
  passwordHash      String
  displayName       String
  birthDate         DateTime
  gender            Gender
  interestedIn      InterestedIn
  bio               String?
  jobTitle          String?
  avatarUrl         String?
  city              String?
  latitude          Decimal?                  @db.Decimal(9, 6)
  longitude         Decimal?                  @db.Decimal(9, 6)
  isLocationPrecise Boolean                   @default(false)
  isStoryPublic     Boolean                   @default(true)
  lastActiveAt      DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  photos            UserPhoto[]
  interests         UserInterest[]
  stories           Story[]
  likesSent         Like[]                    @relation("likes_sent")
  likesReceived     Like[]                    @relation("likes_received")
  matchesAsUser1    Match[]                   @relation("match_user_1")
  matchesAsUser2    Match[]                   @relation("match_user_2")
  shares            Share[]
  blocksInitiated   Block[]                   @relation("blocker")
  blocksReceived    Block[]                   @relation("blocked")
  reportsFiled      Report[]                  @relation("reporter")
  reportsAgainst    Report[]                  @relation("reported_user")
  conversationLinks ConversationParticipant[]
  messages          Message[]
  messageReceipts   MessageReceipt[]
  notifications     Notification[]
  messageReactions  MessageReaction[]
  
  groupConversationsCreated GroupConversation[] @relation("created_by")
  groupConversationMembers  GroupConversationMember[]
  
  callsMade     Call[] @relation("CallCaller")
  callsReceived Call[] @relation("CallReceiver")
  groupMessages             GroupMessage[]
  groupMessageReactions     GroupMessageReaction[]
  
  notificationPreferences   NotificationPreferences?
  pushSubscriptions         PushSubscription[]

  @@index([latitude, longitude])
  @@index([lastActiveAt])
}

model UserPhoto {
  id        String   @id @default(uuid())
  userId    String
  photoUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model UserInterest {
  id           String @id @default(uuid())
  userId       String
  interestName String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, interestName])
}

model Like {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  createdAt  DateTime @default(now())

  fromUser User @relation("likes_sent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("likes_received", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
}

model Match {
  id        String      @id @default(uuid())
  user1Id   String
  user2Id   String
  status    MatchStatus @default(active)
  matchedAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user1 User @relation("match_user_1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("match_user_2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
}

model Story {
  id          String         @id @default(uuid())
  userId      String
  mediaType   StoryMediaType
  mediaUrl    String?
  textContent String?
  caption     String?
  createdAt   DateTime       @default(now())
  expiresAt   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Share {
  id         String          @id @default(uuid())
  userId     String
  targetType ShareTargetType
  targetId   String
  channel    String
  createdAt  DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
}

model Block {
  id            String   @id @default(uuid())
  blockerUserId String
  blockedUserId String
  reason        String?
  createdAt     DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
}

model Report {
  id             String       @id @default(uuid())
  reporterUserId String
  reportedUserId String?
  targetType     String
  targetId       String?
  reason         String
  details        String?
  status         ReportStatus @default(open)
  createdAt      DateTime     @default(now())

  reporter     User  @relation("reporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reportedUser User? @relation("reported_user", fields: [reportedUserId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([status, createdAt])
}

model Conversation {
  id           String                    @id @default(uuid())
  type         ConversationType          @default(direct)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
  calls        Call[]

  @@index([updatedAt])
}

model MessageReceipt {
  id          String   @id @default(uuid())
  messageId   String
  userId      String
  deliveredAt DateTime?
  seenAt      DateTime?
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, deliveredAt, seenAt])
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, joinedAt])
}

model Message {
  id               String      @id @default(uuid())
  conversationId   String
  senderUserId     String
  parentMessageId  String?
  messageType      MessageType @default(text)
  textContent      String?
  mediaUrl         String?
  fileName         String?
  mimeType         String?
  fileSize         Int?
  durationSeconds  Int?
  forwardedFromMessageId String?
  pinnedAt         DateTime?
  createdAt        DateTime    @default(now())
  deliveredAt      DateTime?
  seenAt           DateTime?
  recalledAt       DateTime?
  deletedAt        DateTime?

  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  parentMessage  Message?          @relation("MessageReply", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies        Message[]         @relation("MessageReply")
  forwardedFromMessage Message?     @relation("MessageForward", fields: [forwardedFromMessageId], references: [id], onDelete: SetNull)
  forwardedMessages Message[]       @relation("MessageForward")
  receipts       MessageReceipt[]
  reactions      MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([parentMessageId])
  @@index([forwardedFromMessageId])
  @@index([conversationId, pinnedAt])
}

model MessageReaction {
  id         String   @id @default(uuid())
  messageId   String
  userId      String
  emoji       String
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId, createdAt])
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  body        String?
  data        Json?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  readAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

// ============ GROUP CHAT MODELS ============

model GroupConversation {
  id              String                    @id @default(uuid())
  name            String
  description     String?
  avatarUrl       String?
  createdByUserId String
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  createdBy User                        @relation("created_by", fields: [createdByUserId], references: [id], onDelete: Cascade)
  members   GroupConversationMember[]
  messages  GroupMessage[]

  @@index([createdAt])
  @@index([updatedAt])
}

model GroupConversationMember {
  id                  String   @id @default(uuid())
  groupConversationId String
  userId              String
  joinedAt            DateTime @default(now())
  lastReadAt          DateTime?
  role                GroupMemberRole @default(member)

  groupConversation GroupConversation @relation(fields: [groupConversationId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupConversationId, userId])
  @@index([groupConversationId])
  @@index([userId, joinedAt])
}

model GroupMessage {
  id                  String   @id @default(uuid())
  groupConversationId String
  senderUserId        String
  parentMessageId     String?
  messageType         MessageType @default(text)
  textContent         String?
  mediaUrl            String?
  fileName            String?
  mimeType            String?
  fileSize            Int?
  durationSeconds     Int?
  pinnedAt            DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  recalledAt          DateTime?
  deletedAt           DateTime?

  groupConversation GroupConversation       @relation(fields: [groupConversationId], references: [id], onDelete: Cascade)
  sender            User                   @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  parentMessage     GroupMessage?          @relation("GroupMessageReply", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies           GroupMessage[]         @relation("GroupMessageReply")
  reactions         GroupMessageReaction[]

  @@index([groupConversationId, createdAt])
  @@index([groupConversationId, pinnedAt])
  @@index([senderUserId])
  @@index([parentMessageId])
}

model GroupMessageReaction {
  id            String   @id @default(uuid())
  groupMessageId String
  userId        String
  emoji         String
  createdAt     DateTime @default(now())

  groupMessage GroupMessage @relation(fields: [groupMessageId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupMessageId, userId, emoji])
  @@index([groupMessageId, createdAt])
}

// ============ VIDEO/VOICE CALL MODELS ============

enum CallType {
  video
  voice
}

enum CallStatus {
  ringing
  connected
  ended
  missed
  rejected
}

model Call {
  id             String     @id @default(uuid())
  conversationId String
  callerId       String
  receiverId     String
  callType       CallType
  status         CallStatus @default(ringing)
  startedAt      DateTime?
  endedAt        DateTime?
  durationSeconds Int?
  createdAt      DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  caller       User         @relation("CallCaller", fields: [callerId], references: [id], onDelete: Cascade)
  receiver     User         @relation("CallReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([callerId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
}

// ============ NOTIFICATION PREFERENCES MODELS ============

model NotificationPreferences {
  id                String   @id @default(uuid())
  userId            String   @unique
  newMatch          Boolean  @default(true)
  newMessage        Boolean  @default(true)
  newLike           Boolean  @default(true)
  incomingCall      Boolean  @default(true)
  missedCall        Boolean  @default(true)
  storyReaction     Boolean  @default(true)
  groupMessage      Boolean  @default(true)
  pushEnabled       Boolean  @default(true)
  soundEnabled      Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}
